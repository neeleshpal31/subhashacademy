# Copy this file to .env for local use (optional)
# Do NOT commit real secrets.

DATABASE_URL=postgresql://postgres:password@localhost:5432/college_db
SQLITE_SOURCE_PATH=college.db
FLASK_SECRET_KEY=change-this-in-production
FLASK_SECURE_COOKIE=0

# Optional: set to 1 in production

FLASK_DEBUG=1
PORT=5000
